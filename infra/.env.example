COMPOSE_PROJECT_NAME=sonicrelay
COMPOSE_FILE=compose.yml:compose.dev.yml
COMPOSE_PROFILES=dev
ASPNETCORE_ENVIRONMENT=Development
API_PUBLIC_BASE_URL=http://localhost:8080
API_IMAGE=sonicrelay-api:local
POSTGRES_VERSION=17-alpine
POSTGRES_DB=sonicrelay
POSTGRES_USER=sonicrelay
POSTGRES_PASSWORD=sonicrelay-dev-password
REDIS_VERSION=7-alpine
REDIS_PASSWORD=sonicrelay-dev-redis-password
AUTH_ACCESS_TOKEN_MINUTES=15
AUTH_REFRESH_TOKEN_DAYS=30
AUTH_REQUIRE_CONFIRMED_EMAIL=false
SESSION_CODE_TTL_MINUTES=10
SESSION_MAX_VIEWERS=3
SESSION_IDLE_TIMEOUT_MINUTES=5
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_JOIN_SESSION_PER_MINUTE=10
RATE_LIMIT_CREATE_SESSION_PER_MINUTE=10
TURN_PUBLIC_HOST=turn.localhost
TURN_REALM=sonicrelay.local
TURN_STATIC_AUTH_SECRET=dev-turn-secret-change-me
COTURN_VERSION=latest
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin
